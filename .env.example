# ===== 后端配置 =====
# API 服务器配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ===== 前端配置 =====
# 前端 API 基础 URL (Vite 用法: import.meta.env.VITE_API_URL)
VITE_API_URL=http://localhost:8000/api

# ===== 数据存储配置 =====
# 文件存储路径
DATA_DIR=./backend/data
UPLOADS_DIR=./backend/data/uploads
PROCESSED_DIR=./backend/data/processed
METADATA_DIR=./backend/data/metadata
VECTOR_INDEX_DIR=./backend/data/vector_index
REPORTS_DIR=./backend/data/reports

# ===== 模型和 LLM 配置 =====
# 优先使用环境变量传入
# LLM_PROVIDER=openai  # 可选: openai, anthropic, local
# LLM_MODEL=gpt-3.5-turbo
# LLM_API_KEY=your_api_key_here

# ===== 向量数据库配置 =====
# FAISS 配置
VECTOR_DB_TYPE=faiss
VECTOR_DB_PATH=./backend/data/vector_index

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=./backend/logs/app.log

# ===== 功能开关 =====
# 是否启用 RAG 功能
ENABLE_RAG=true

# 是否启用知识图谱合并
ENABLE_KG_MERGE=true

# 是否启用自动报告生成
ENABLE_AUTO_REPORT=true

# ===== 性能配置 =====
# 最大文件上传大小（字节）
MAX_UPLOAD_SIZE=104857600

# 文本分块大小
CHUNK_SIZE=1000

# RAG 查询返回的最大结果数
RAG_MAX_TOP_K=20

# ===== 开发配置 =====
# 是否使用 Mock 数据
USE_MOCK_DATA=false

# 是否启用详细日志
DEBUG_MODE=false
